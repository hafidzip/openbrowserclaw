from main import ToolRegistry, ActionResult, get_node, get_children_node
from typing import Any, Dict, List, Optional

initial_task = """
{{current_task}}
"""

async def llm_tool(
    query: str,
    tool_registry: Optional[Dict[str, ToolRegistry]] = None,
) -> Dict[str, Any]:
    """
    Sends `query` to the language model, optionally supplying callable tools from
    `tool_registry`, and returns a dict containing the model's response text and
    any tool-use results.
    """
    ...

# Tools
async def agent_query(query: str) -> str:
    """
    Delegate tasks to sub-agents.
    """
    ...

async def read_file(query: str) -> str:
    """
    Read content from a file.
    """
    ...

async def web_search(query: str) -> str:
    """
    Search the web for information.
    """
    ...

async def main() -> List[Dict[str, Any]]:
    """
    Entry-point coroutine: runs the planner_agent node on `initial_task`, fans out
    to any follow-up branch tasks declared in the returned ActionResult, and returns
    the collected list of all result payloads.
    """
    results: List[Dict[str, Any]] = []
    node = get_node("planner_agent")
    data: ActionResult = await node.execute(initial_task)
    results.append(data.result)
    # (parent_node, branch_id, task)
    queue: deque[tuple] = deque()
    if data.next_branch and len(data.next_tasks) > 0:
        for task in data.next_tasks:
            queue.append((node, data.next_branch, task))
    while queue:
        parent_node, branch_id, task = queue.popleft()
        branch_node = get_children_node(parent_node, branch_id)
        branch_data: ActionResult = await branch_node.execute(task)
        results.append(branch_data.result)
        if branch_data.next_branch and len(branch_data.next_tasks) > 0:
            for t in branch_data.next_tasks:
                queue.append((branch_node, branch_data.next_branch, t))
    return results
```

