import sys
import importlib.util
from collections import deque
from dataclasses import dataclass, field
from typing import Any, Awaitable, Callable, Dict, List, Optional


class ToolRegistry:
    call: Callable[..., Awaitable[Dict[str, Any]]]
    schema: Dict[str, Any]

    def __init__(
        self,
        call: Callable[..., Awaitable[Dict[str, Any]]],
        schema: Dict[str, Any],
    ):
        self.call = call
        self.schema = schema

    async def execute(self, **kwargs) -> Dict[str, Any]:
        return await self.call(**kwargs)


def load(path: str, name: str) -> Any:
    """Dynamically loads a Python module from `path`, registers it in sys.modules under `name`, and returns the loaded module object."""
    ...

@dataclass
class ActionResult:
    result: Dict[str, Any]
    next_tasks: List[str] = field(default_factory=list)
    next_branch: Optional[str] = None


@dataclass
class Skill:
    path: str
    description: str


@dataclass
class Node:
    name: str
    skill: Skill
    available_tools: List[str]
    module_path: str
    module_name: str
    children: List["Node"] = field(default_factory=list)
    _module: Any = field(default=None, init=False, repr=False)

    @property
    def module(self) -> Any:
        """Lazily load the node's module on first access."""
        if self._module is None:
            self._module = load(self.module_path, self.module_name)
        return self._module

    async def execute(self, task: str = "") -> "ActionResult":
        return await self.module.execute(task)


def get_node(name: str) -> "Node":
    """BFS search for a node by name starting from the root tree."""
    ...


def get_children_node(node: Node, name: str) -> "Node":
    """Search for a children node by name, only search in node->children, non-recursive."""
    ...

