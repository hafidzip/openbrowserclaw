        description="Description for planner.md",
    ),
    available_tools=["agent_query", "read_file", "web_search"],
    module_path="planner_agent/main.py",
    module_name="planner_agent",
    children=[
        Node(
            name="writer_agent",
            skill=Skill(
                path="/skills/writer.md",
                description="Description for writer.md",
            ),
            available_tools=["write_file"],
            module_path="writer_agent/main.py",
            module_name="writer_agent",
        ),
    ],
)
