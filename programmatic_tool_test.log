    Entry-point coroutine: runs the planner_agent node on `initial_task`, fans out
    to any follow-up branch tasks declared in the returned ActionResult, and returns
    the collected list of all result payloads.
    """
    results: List[Dict[str, Any]] = []
    node = get_node("planner_agent")
    data: ActionResult = await node.execute(initial_task)
    results.append(data.result)
    if data.next_branch and len(data.next_tasks) > 0:
        for task in data.next_tasks:
            branch_node = get_children_node(node, data.next_branch)
            branch_data: ActionResult = await branch_node.execute(task)
            results.append(branch_data.result)
    return results
```

