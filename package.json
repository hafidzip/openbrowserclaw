    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "baseline-browser-mapping": "^2.10.30",
    "esbuild": "^0.27.3",
    "postcss": "^8.5.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vite-plugin-splash-screen": "^0.2.2",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}